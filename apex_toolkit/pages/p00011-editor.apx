    dynamicAction da-new-job (
        name: New draft job
        execution {
            sequence: 70
        }
        when {
            event: click
            selectionType: button
            button: @new-job
        }
        action srv-new-job (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                      :P11_JOB_ID := pck_kml_job_api.create_job(
                                       p_document_name => 'Editor draft',
                                       p_output_format => 'KMZ');
                      commit;
                    end;
                    ```
                itemsToReturn: P11_JOB_ID
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )
        action refresh-job-lov (
            action: refresh
            affectedElements {
                selectionType: items
                items: P11_JOB_ID
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
