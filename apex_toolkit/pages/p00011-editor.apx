    dynamicAction da-add-asset (
        name: Add as asset
        execution {
            sequence: 80
        }
        when {
            event: click
            selectionType: button
            button: @add-asset
        }
        action srv-add-asset (
            action: executeServerSideCode
            settings {
                itemsToSubmit: P11_JOB_ID,P11_ASSET_ID,P11_GEOJSON,P11_NAME,P11_FOLDER,P11_LINE_COLOR,P11_LINE_WIDTH,P11_POLY_COLOR,P11_POLY_ALPHA,P11_POLY_FILL,P11_POLY_OUTLINE,P11_LABEL_COLOR,P11_LABEL_SCALE,P11_ICON_HREF,P11_ICON_SCALE,P11_ALTITUDE_MODE,P11_EXTRUDE,P11_TESSELLATE
                plsqlCode:
                    ```plsql
                    declare
                      l_job number := to_number(:P11_JOB_ID);
                      l_a   number;
                      l_line  varchar2(8) := case when :P11_LINE_COLOR  is not null then pck_kml_engine.rgba_to_kml(ltrim(:P11_LINE_COLOR,'#')) end;
                      l_poly  varchar2(8) := case when :P11_POLY_COLOR  is not null then pck_kml_engine.rgba_to_kml(ltrim(:P11_POLY_COLOR,'#'), nvl(:P11_POLY_ALPHA,128)) end;
                      l_label varchar2(8) := case when :P11_LABEL_COLOR is not null then pck_kml_engine.rgba_to_kml(ltrim(:P11_LABEL_COLOR,'#')) end;
                    begin
                      if :P11_GEOJSON is null then
                        raise_application_error(-20900, 'Draw a geometry first.');
                      end if;
                      if :P11_ASSET_ID is not null then
                        -- update the selected asset in place
                        pck_kml_job_assets_dml.upd(
                          p_asset_id         => to_number(:P11_ASSET_ID),
                          p_geometry_geojson => to_clob(:P11_GEOJSON),
                          p_name             => :P11_NAME,
                          p_folder_name      => :P11_FOLDER,
                          p_line_color       => l_line,
                          p_line_width       => :P11_LINE_WIDTH,
                          p_poly_color       => l_poly,
                          p_poly_fill        => :P11_POLY_FILL,
                          p_poly_outline     => :P11_POLY_OUTLINE,
                          p_label_color      => l_label,
                          p_label_scale      => :P11_LABEL_SCALE,
                          p_icon_href        => :P11_ICON_HREF,
                          p_icon_scale       => :P11_ICON_SCALE,
                          p_altitude_mode    => :P11_ALTITUDE_MODE,
                          p_extrude          => nvl(:P11_EXTRUDE,'N'),
                          p_tessellate       => nvl(:P11_TESSELLATE,'N'));
                        commit;
                      else
                        if l_job is null then
                          l_job := pck_kml_job_api.create_job(
                                     p_document_name => 'Editor draft',
                                     p_output_format => 'KMZ');
                        end if;
                        l_a := pck_kml_job_api.add_asset(
                                 p_job_id           => l_job,
                                 p_geometry_geojson => to_clob(:P11_GEOJSON),
                                 p_name             => :P11_NAME,
                                 p_folder_name      => :P11_FOLDER,
                                 p_line_color       => l_line,
                                 p_line_width       => :P11_LINE_WIDTH,
                                 p_poly_color       => l_poly,
                                 p_poly_fill        => :P11_POLY_FILL,
                                 p_poly_outline     => :P11_POLY_OUTLINE,
                                 p_label_color      => l_label,
                                 p_label_scale      => :P11_LABEL_SCALE,
                                 p_icon_href        => :P11_ICON_HREF,
                                 p_icon_scale       => :P11_ICON_SCALE,
                                 p_altitude_mode    => :P11_ALTITUDE_MODE,
                                 p_extrude          => nvl(:P11_EXTRUDE,'N'),
                                 p_tessellate       => nvl(:P11_TESSELLATE,'N'));
                        commit;
                        -- return the (possibly new) job via a helper so we can set
                        -- P11_JOB_ID client-side WITHOUT firing its change handler
                        :P11_NEW_JOB  := l_job;
                        :P11_ASSET_ID := l_a;   -- keep the new asset selected for further edits
                      end if;
                    end;
                    ```
                itemsToReturn: P11_NEW_JOB,P11_ASSET_ID
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )
        action js-set-job (
            action: executeJsCode
            settings {
                jsCode: var nj=apex.item('P11_NEW_JOB').getValue(); if(nj){ var s=document.getElementById('P11_JOB_ID'); if(s && ![].some.call(s.options,function(o){return o.value==nj;})){ s.add(new Option('Editor draft (#'+nj+', DRAFT)', nj)); } apex.item('P11_JOB_ID').setValue(nj, null, true); }
            }
            execution {
                sequence: 15
                fireOnInit: false
            }
        )
        action refresh-asset-lov (
            action: refresh
            affectedElements {
                selectionType: region
                region: @assetgrid
            }
            execution {
                sequence: 25
                fireOnInit: false
            }
        )
        action msg-add (
            action: showSuccessMessage
            settings {
                message: Asset saved - it stays loaded so you can keep editing.
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )
    )

    dynamicAction da-build-output (
        name: Build snippet and KML
        execution {
            sequence: 90
        }
        when {
            event: click
            selectionType: button
            button: @build-output
        }
        action srv-build (
            action: executeServerSideCode
            settings {
                itemsToSubmit: P11_JOB_ID,P11_GEOJSON,P11_NAME,P11_FOLDER,P11_LINE_COLOR,P11_LINE_WIDTH,P11_POLY_COLOR,P11_POLY_ALPHA,P11_POLY_FILL,P11_POLY_OUTLINE,P11_LABEL_COLOR,P11_LABEL_SCALE,P11_ICON_HREF,P11_ICON_SCALE,P11_ALTITUDE_MODE,P11_EXTRUDE,P11_TESSELLATE,P11_REST_BASE
                itemsToReturn: P11_SNIPPET,P11_KML_STYLE,P11_REST_ASSET,P11_REST_JOB
                plsqlCode:
                    ```plsql
                    declare
                      l_snip  clob;
                      l_kml   clob;
                      l_ras   clob;
                      l_rjob  clob;
                    begin
                      pck_kmleon_tools.style_outputs(
                        p_geojson       => to_clob(:P11_GEOJSON),
                        p_name          => :P11_NAME,
                        p_folder_name   => :P11_FOLDER,
                        p_line_color    => :P11_LINE_COLOR,
                        p_line_width    => :P11_LINE_WIDTH,
                        p_poly_color    => :P11_POLY_COLOR,
                        p_poly_alpha    => nvl(:P11_POLY_ALPHA,128),
                        p_poly_fill     => :P11_POLY_FILL,
                        p_poly_outline  => :P11_POLY_OUTLINE,
                        p_label_color   => :P11_LABEL_COLOR,
                        p_label_scale   => :P11_LABEL_SCALE,
                        p_icon_href     => :P11_ICON_HREF,
                        p_icon_scale    => :P11_ICON_SCALE,
                        p_altitude_mode => :P11_ALTITUDE_MODE,
                        p_extrude       => nvl(:P11_EXTRUDE,'N'),
                        p_tessellate    => nvl(:P11_TESSELLATE,'N'),
                        p_snippet       => l_snip,
                        p_kml_style     => l_kml);
                      pck_kmleon_tools.rest_outputs(
                        p_job_id        => to_number(:P11_JOB_ID),
                        p_geojson       => to_clob(:P11_GEOJSON),
                        p_name          => :P11_NAME,
                        p_folder_name   => :P11_FOLDER,
                        p_line_color    => :P11_LINE_COLOR,
                        p_line_width    => :P11_LINE_WIDTH,
                        p_poly_color    => :P11_POLY_COLOR,
                        p_poly_alpha    => nvl(:P11_POLY_ALPHA,128),
                        p_poly_fill     => :P11_POLY_FILL,
                        p_poly_outline  => :P11_POLY_OUTLINE,
                        p_label_color   => :P11_LABEL_COLOR,
                        p_label_scale   => :P11_LABEL_SCALE,
                        p_icon_href     => :P11_ICON_HREF,
                        p_icon_scale    => :P11_ICON_SCALE,
                        p_altitude_mode => :P11_ALTITUDE_MODE,
                        p_extrude       => nvl(:P11_EXTRUDE,'N'),
                        p_tessellate    => nvl(:P11_TESSELLATE,'N'),
                        p_base_url      => nvl(:P11_REST_BASE, 'https://HOST/ords/SCHEMA/kmleon/v1'),
                        p_asset_rest    => l_ras,
                        p_job_rest      => l_rjob);
                      :P11_SNIPPET    := l_snip;
                      :P11_KML_STYLE  := l_kml;
                      :P11_REST_ASSET := l_ras;
                      :P11_REST_JOB   := l_rjob;
                    end;
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )
        action msg-build (
            action: showSuccessMessage
            settings {
                message: Code built below - PL/SQL add_asset, KML style, and REST (curl) for the asset and the whole job.
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )
    )

    dynamicAction da-run-job (
