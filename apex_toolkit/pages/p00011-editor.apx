    region assetgrid (
        name: Assets in this job
        type: interactiveGrid
        layout {
            sequence: 12
            slot: body
            columnSpan: 12
            startNewRow: true
        }
        advanced {
            htmlDomId: assetgrid
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select asset_id,
                       name,
                       case when geometry_geojson is not null then 'GeoJSON'
                            when geometry_sdo is not null then 'SDO' end as geom,
                       folder_name,
                       line_color,
                       poly_color
                  from kml_job_assets
                 where job_id = to_number(:P11_JOB_ID)
                 order by display_order, asset_id
                ```
            pageItemsToSubmit: P11_JOB_ID
        }
        edit {
            enabled: false
        }
        pagination {
            type: page
            showTotalCount: true
        }
        messages {
            whenNoDataFound: No assets yet - draw one and Save it.
        }
        toolbar {
            controls: [
                searchField
                actionsMenu
            ]
        }

        savedReport PRIMARY (
            name: Primary
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }
            displayColumn (
                column: @APEX$ROW_SELECTOR
                layout {
                    sequence: 0
                }
            )
            displayColumn (
                column: @NAME
                layout {
                    sequence: 1
                }
            )
            displayColumn (
                column: @GEOM
                layout {
                    sequence: 2
                }
            )
            displayColumn (
                column: @FOLDER_NAME
                layout {
                    sequence: 3
                }
            )
            displayColumn (
                column: @LINE_COLOR
                layout {
                    sequence: 4
                }
            )
            displayColumn (
                column: @POLY_COLOR
                layout {
                    sequence: 5
                }
            )
        )

        column APEX$ROW_SELECTOR (
            type: rowSelector
            layout {
                sequence: 10
            }
        )
        column ASSET_ID (
            type: hidden
            layout {
                sequence: 20
            }
            source {
                databaseColumn: ASSET_ID
                dataType: number
                primaryKey: true
            }
        )
        column NAME (
            type: textField
            heading {
                heading: Name
            }
            layout {
                sequence: 30
            }
            source {
                databaseColumn: NAME
                dataType: varchar2
            }
        )
        column GEOM (
            type: textField
            heading {
                heading: Geometry
            }
            layout {
                sequence: 40
            }
            source {
                databaseColumn: GEOM
                dataType: varchar2
            }
        )
        column FOLDER_NAME (
            type: textField
            heading {
                heading: Folder
            }
            layout {
                sequence: 50
            }
            source {
                databaseColumn: FOLDER_NAME
                dataType: varchar2
            }
        )
        column LINE_COLOR (
            type: textField
            heading {
                heading: Line
            }
            layout {
                sequence: 60
            }
            source {
                databaseColumn: LINE_COLOR
                dataType: varchar2
            }
        )
        column POLY_COLOR (
            type: textField
            heading {
                heading: Fill
            }
            layout {
                sequence: 70
            }
            source {
                databaseColumn: POLY_COLOR
                dataType: varchar2
            }
        )
    )

