    pageItem P11_ALTITUDE_MODE (
        type: selectList
        label {
            label: Altitude mode
        }
        layout {
            sequence: 130
            region: @style
            slot: regionBody
            columnSpan: 4
        }
        appearance {
            template: @/optional-floating
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select 'clampToGround'    as d, 'clampToGround'    as r from dual
                union all
                select 'relativeToGround' as d, 'relativeToGround' as r from dual
                union all
                select 'absolute'         as d, 'absolute'         as r from dual
                ```
            displayNullValue: true
        }
    )

