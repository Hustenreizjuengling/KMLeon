    process init-defaults (
        name: Initialise inputs
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  :P11_LINE_COLOR  := nvl(:P11_LINE_COLOR, '#3388ff');
                  :P11_POLY_COLOR  := nvl(:P11_POLY_COLOR, '#3388ff');
                  :P11_LINE_WIDTH  := nvl(:P11_LINE_WIDTH, 2);
                  :P11_POLY_ALPHA  := nvl(:P11_POLY_ALPHA, 128);
                  :P11_POLY_FILL   := nvl(:P11_POLY_FILL, 'Y');
                  :P11_POLY_OUTLINE := nvl(:P11_POLY_OUTLINE, 'Y');
                  :P11_EXTRUDE     := nvl(:P11_EXTRUDE, 'N');
                  :P11_TESSELLATE  := nvl(:P11_TESSELLATE, 'N');
                end;
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
    )

