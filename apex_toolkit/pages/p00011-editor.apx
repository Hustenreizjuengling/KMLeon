page 11 (
    name: Editor
    alias: EDITOR
    title: KMLeon - Editor
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            window.kmleonEditor = (function () {
                var map = null, regionId = "editmap", type = null, coords = [], SRC = "kmlDraw", inited = false;

                function geom() {
                    if (type === "Point")      return coords.length ? { type: "Point", coordinates: coords[0] } : null;
                    if (type === "LineString") return coords.length >= 2 ? { type: "LineString", coordinates: coords.slice() } : null;
                    if (type === "Polygon") {
                        if (coords.length < 3) return null;
                        var r = coords.slice(); r.push(coords[0]);
                        return { type: "Polygon", coordinates: [r] };
                    }
                    return null;
                }
                function fc() {
                    var feats = [], g = geom();
                    if (g) feats.push({ type: "Feature", properties: {}, geometry: g });
                    if (type === "LineString" || type === "Polygon") {
                        coords.forEach(function (c) {
                            feats.push({ type: "Feature", properties: { vertex: 1 }, geometry: { type: "Point", coordinates: c } });
                        });
                    }
                    return { type: "FeatureCollection", features: feats };
                }
                function redraw() {
                    if (map && map.getSource(SRC)) { map.getSource(SRC).setData(fc()); }
                    var g = geom();
                    apex.item("P11_GEOJSON").setValue(g ? JSON.stringify(g) : "");
                }
                function bounds() {
                    if (!coords.length) { return null; }
                    var minx = 180, miny = 90, maxx = -180, maxy = -90;
                    coords.forEach(function (c) {
                        if (c[0] < minx) minx = c[0]; if (c[0] > maxx) maxx = c[0];
                        if (c[1] < miny) miny = c[1]; if (c[1] > maxy) maxy = c[1];
                    });
                    return [[minx, miny], [maxx, maxy]];
                }
                function applyStyle() {
                    if (!map) { return; }
                    function v(n) { try { return apex.item(n).getValue(); } catch (e) { return null; } }
                    var lc = v("P11_LINE_COLOR") || "#3388ff";
                    var pc = v("P11_POLY_COLOR") || "#3388ff";
                    var lw = parseFloat(v("P11_LINE_WIDTH")) || 2;
                    var pa = (parseFloat(v("P11_POLY_ALPHA")) || 128) / 255;
                    var fill = v("P11_POLY_FILL") !== "N";
                    if (map.getLayer("kmlFill"))  { map.setPaintProperty("kmlFill", "fill-color", pc); map.setPaintProperty("kmlFill", "fill-opacity", fill ? pa : 0); }
                    if (map.getLayer("kmlLine"))  { map.setPaintProperty("kmlLine", "line-color", lc); map.setPaintProperty("kmlLine", "line-width", lw); }
                    if (map.getLayer("kmlPoint")) { map.setPaintProperty("kmlPoint", "circle-color", lc); }
                }
                function onClick(e) {
                    if (!type) { return; }
                    var c = [e.lngLat.lng, e.lngLat.lat];
                    if (type === "Point") { coords = [c]; } else { coords.push(c); }
                    redraw();
                }
                function markActive(t) {
                    ["point", "line", "polygon"].forEach(function (m) {
                        var el = document.getElementById("B_" + m.toUpperCase());
                        if (el) { el.classList.toggle("kml-tool-active", m === t); }
                    });
                }
                return {
                    init: function () {
                        if (inited) { return; }
                        var r = apex.region(regionId);
                        if (!r) { return; }
                        map = (typeof r.getMapObject === "function") ? r.getMapObject() : null;
                        if (!map) { return; }
                        inited = true;
                        if (!map.getSource(SRC)) {
                            map.addSource(SRC, { type: "geojson", data: fc() });
                            map.addLayer({ id: "kmlFill", type: "fill", source: SRC, filter: ["==", "$type", "Polygon"],
                                paint: { "fill-color": "#3388ff", "fill-opacity": 0.4 } });
                            map.addLayer({ id: "kmlLine", type: "line", source: SRC, filter: ["in", "$type", "LineString", "Polygon"],
                                paint: { "line-color": "#3388ff", "line-width": 2 } });
                            map.addLayer({ id: "kmlPoint", type: "circle", source: SRC, filter: ["==", "$type", "Point"],
                                paint: { "circle-radius": 5, "circle-color": "#3388ff", "circle-stroke-width": 1, "circle-stroke-color": "#ffffff" } });
                        }
                        map.on("click", onClick);
                        map.on("dblclick", function (e) { if (type === "LineString" || type === "Polygon") { e.preventDefault(); kmleonEditor.finish(); } });
                        ["P11_LINE_COLOR", "P11_POLY_COLOR", "P11_LINE_WIDTH", "P11_POLY_ALPHA", "P11_POLY_FILL"].forEach(function (n) {
                            try { apex.item(n).element.on("change", applyStyle); } catch (e) {}
                        });
                        applyStyle();
                    },
                    setMode: function (t) {
                        type = (t === "point") ? "Point" : (t === "line") ? "LineString" : (t === "polygon") ? "Polygon" : null;
                        coords = [];
                        markActive(t);
                        if (map && map.doubleClickZoom) { if (type === "LineString" || type === "Polygon") { map.doubleClickZoom.disable(); } else { map.doubleClickZoom.enable(); } }
                        redraw();
                        apex.message.showPageSuccess("Draw mode: " + t + " - click on the map (double-click finishes a line/polygon).");
                    },
                    undo: function () { if (coords.length) { coords.pop(); } redraw(); },
                    clear: function () { type = null; coords = []; markActive(null); redraw(); },
                    finish: function () { redraw(); apex.message.showPageSuccess("Geometry captured. Set the style, then save it as an asset or build the snippet."); },
                    load: function (gjStr) {
                        try {
                            var g = JSON.parse(gjStr);
                            if (g && g.type === "FeatureCollection" && g.features && g.features.length) { g = g.features[0].geometry; }
                            else if (g && g.type === "Feature") { g = g.geometry; }
                            if (!g || !g.type) { return; }
                            if (g.type === "Point") { type = "Point"; coords = [g.coordinates]; }
                            else if (g.type === "LineString") { type = "LineString"; coords = g.coordinates.slice(); }
                            else if (g.type === "Polygon") {
                                type = "Polygon";
                                var r = g.coordinates[0].slice();
                                if (r.length > 1 && r[0][0] === r[r.length-1][0] && r[0][1] === r[r.length-1][1]) { r.pop(); }
                                coords = r;
                            } else { return; }
                            redraw();
                            applyStyle();
                            var b = bounds();
                            if (map && b) { try { map.fitBounds(b, { padding: 60, maxZoom: 15, duration: 600 }); } catch (e) {} }
                        } catch (e) {}
                    },
                    applyStyle: applyStyle
                };
            })();
            ```
        executeWhenPageLoads:
            ```javascript-browser
            (function () {
                function ready() {
                    try { var r = apex.region("editmap"); return r && typeof r.getMapObject === "function" && r.getMapObject(); }
                    catch (e) { return false; }
                }
                function tryInit(n) {
                    if (ready()) { window.kmleonEditor.init(); return; }
                    if (n > 0) { setTimeout(function () { tryInit(n - 1); }, 500); }
                }
                apex.jQuery("#editmap").on("spatialmapinitialized", function () { window.kmleonEditor.init(); });
                tryInit(30);
            })();
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region job (
        name: Job
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        advanced {
            htmlDomId: job
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        source {
            htmlCode:
                ```html
                <style>
                  /* Neutral, minimal: lean on the Universal Theme. */
                  /* job bar: select grows, buttons grouped neatly on the right */
                  #job .t-Region-body { display:flex; flex-wrap:wrap; align-items:flex-end; gap:8px; }
                  #job .t-Form-fieldContainer { flex:1 1 260px; margin:0; }
                  #job .t-Button { margin:0; flex:0 0 auto; }
                  #job .kml-intro { flex:1 1 100%; order:-1; margin:0 0 6px; color:#707070; font-size:13px; line-height:1.5; }
                  /* draw buttons: even, equal-width 3-up toolbar at top of the sidebar */
                  #style #B_POINT, #style #B_LINE, #style #B_POLYGON,
                  #style #B_FINISH, #style #B_UNDO, #style #B_CLEAR {
                    width:calc(33.333% - 8px) !important; display:inline-flex !important;
                    justify-content:center; margin:0 4px 6px 0 !important; padding-left:0; padding-right:0;
                  }
                  .kml-tool-active, .kml-tool-active:hover { background:#0072c6 !important; border-color:#0072c6 !important; color:#fff !important; }
                  .kml-tool-active .t-Icon { color:#fff !important; }
                  /* style sidebar beside the map: one column, scrolls */
                  #style .t-Region-body { max-height:600px; overflow-y:auto; }
                  #style .t-Form-fieldContainer { width:100% !important; max-width:100% !important; }
                  /* output code areas */
                  #out textarea { min-height:180px; font-family:ui-monospace,Consolas,Menlo,monospace; font-size:12.5px; }
                </style>
                <p class="kml-intro">
                  <b>Draw</b> a geometry on the map, <b>style</b> it with live preview, then
                  <b>Save</b> it to a job (pick one above or let the editor create a draft). Click a
                  row in the assets grid to <b>edit</b> it, or <b>Build snippet &amp; KML</b> to copy a ready-made
                  <code>add_asset</code> call and the raw KML style XML. <b>Run job</b> + <b>Download</b>
                  verify the rendered KML/KMZ.
                </p>
                ```
        }
    )

    pageItem P11_JOB_ID (
        type: selectList
        label {
            label: Job
        }
        layout {
            sequence: 10
            region: @job
            slot: regionBody
        }
        appearance {
            template: @/optional-floating
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select document_name || ' (#' || job_id || ', ' || status || ')' as d, job_id as r
                  from kml_jobs j
                 where status = 'DRAFT'
                    or exists (select 1 from kml_job_assets a where a.job_id = j.job_id)
                 order by job_id desc
                ```
            displayExtraValues: true
            displayNullValue: true
        }
        help {
            helpText: Pick a DRAFT job or any job that still has assets; leave empty and the editor creates a draft when you save the first asset.
        }
    )

    pageItem P11_ASSET_ID (
        type: hidden
        layout {
            sequence: 20
            region: @job
            slot: regionBody
        }
    )

    pageItem P11_NEW_JOB (
        type: hidden
        layout {
            sequence: 21
            region: @job
            slot: regionBody
        }
    )

    pageItem P11_GEOJSON (
        type: hidden
        layout {
            sequence: 99
            region: @job
            slot: regionBody
        }
    )

    button clear-new (
        buttonName: CLEAR_NEW
        label: New / clear
        layout {
            sequence: 40
            region: @job
            slot: regionBody
            startNewRow: false
