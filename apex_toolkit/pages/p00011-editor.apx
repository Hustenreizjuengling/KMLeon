    region editmap (
        name: Map
        type: map
        layout {
            sequence: 20
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: editmap
        }
        map {
            height: 600
        }
        controls {
            options: [
                mousewheelZoom
                scaleBar
                overviewMap
            ]
        }
        initialPositionAndZoom {
            type: sqlQuery
            sqlQuery:
                ```sql
                select 13.40 as map_lon, 52.52 as map_lat, 4 as zoom_level from dual
                ```
            geometryColumnDataType: longitudeLatitude
            initialLongitudeColumn: MAP_LON
            initialLatitudeColumn: MAP_LAT
            initialZoomlevelColumn: ZOOM_LEVEL
        }

        layer saved (
            name: Saved assets
            label {
                label: Saved assets
            }
            layout {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select asset_id as id,
                           name,
                           nvl(geometry_geojson, sdo_util.to_geojson(geometry_sdo)) as geojson
                      from kml_job_assets
                     where job_id = to_number(:P11_JOB_ID)
                    ```
                pageItemsToSubmit: P11_JOB_ID
            }
            columnMapping {
                geometryColumnDataType: geojson
                geojsonColumn: GEOJSON
                primaryKeyColumn: ID
            }
            appearance {
                fillColor: #16a34a
            }
            tooltip {
                advancedFormatting: true
                htmlExpression: &NAME.
            }
        )

    )

