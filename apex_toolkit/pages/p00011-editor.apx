    dynamicAction da-load-asset (
        name: Load or clear on asset change
        execution {
            sequence: 110
        }
        when {
            event: change
            selectionType: items
            items: P11_ASSET_ID
        }
        action srv-load (
            action: executeServerSideCode
            settings {
                itemsToSubmit: P11_ASSET_ID
                itemsToReturn: P11_GEOJSON,P11_NAME,P11_FOLDER,P11_LINE_COLOR,P11_LINE_WIDTH,P11_POLY_COLOR,P11_POLY_ALPHA,P11_POLY_FILL,P11_POLY_OUTLINE,P11_LABEL_COLOR,P11_LABEL_SCALE,P11_ICON_HREF,P11_ICON_SCALE,P11_ALTITUDE_MODE,P11_EXTRUDE,P11_TESSELLATE
                plsqlCode:
                    ```plsql
                    declare
                      l_a kml_job_assets%rowtype;
                    begin
                      if :P11_ASSET_ID is null then
                        -- deselected: clear the form back to drawing defaults
                        :P11_GEOJSON      := null;
                        :P11_NAME         := null;
                        :P11_FOLDER       := null;
                        :P11_LINE_COLOR   := '#3388ff';
                        :P11_LINE_WIDTH   := 2;
                        :P11_POLY_COLOR   := '#3388ff';
                        :P11_POLY_ALPHA   := 128;
                        :P11_POLY_FILL    := 'Y';
                        :P11_POLY_OUTLINE := 'Y';
                        :P11_LABEL_COLOR  := null;
                        :P11_LABEL_SCALE  := null;
                        :P11_ICON_HREF    := null;
                        :P11_ICON_SCALE   := null;
                        :P11_ALTITUDE_MODE := null;
                        :P11_EXTRUDE      := 'N';
                        :P11_TESSELLATE   := 'N';
                      else
                        select * into l_a from kml_job_assets where asset_id = to_number(:P11_ASSET_ID);
                        :P11_GEOJSON      := nvl(l_a.geometry_geojson, sdo_util.to_geojson(l_a.geometry_sdo));
                        :P11_NAME         := l_a.name;
                        :P11_FOLDER       := l_a.folder_name;
                        :P11_LINE_COLOR   := nvl(pck_kmleon_tools.kml_to_rgb(l_a.line_color), '#3388ff');
                        :P11_LINE_WIDTH   := nvl(l_a.line_width, 2);
                        :P11_POLY_COLOR   := nvl(pck_kmleon_tools.kml_to_rgb(l_a.poly_color), '#3388ff');
                        :P11_POLY_ALPHA   := nvl(pck_kmleon_tools.kml_alpha(l_a.poly_color), 128);
                        :P11_POLY_FILL    := nvl(l_a.poly_fill, 'Y');
                        :P11_POLY_OUTLINE := nvl(l_a.poly_outline, 'Y');
                        :P11_LABEL_COLOR  := pck_kmleon_tools.kml_to_rgb(l_a.label_color);
                        :P11_LABEL_SCALE  := l_a.label_scale;
                        :P11_ICON_HREF    := l_a.icon_href;
                        :P11_ICON_SCALE   := l_a.icon_scale;
                        :P11_ALTITUDE_MODE := l_a.altitude_mode;
                        :P11_EXTRUDE      := nvl(l_a.extrude, 'N');
                        :P11_TESSELLATE   := nvl(l_a.tessellate, 'N');
                      end if;
                    end;
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )
        action js-load (
            action: executeJsCode
            settings {
                jsCode: var g = apex.item('P11_GEOJSON').getValue(); if (g) { window.kmleonEditor.load(g); } else { window.kmleonEditor.clear(); }
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )
    )

    dynamicAction da-ig-select (
        name: Asset row selected in the grid
        execution {
            sequence: 108
        }
        when {
            event: region/interactiveGrid/interactivegridselectionchange
            selectionType: region
            region: @assetgrid
        }
        action js-ig-select (
            action: executeJsCode
            settings {
                jsCode: var ig=apex.region('assetgrid').widget().interactiveGrid('instance'),s=ig.getSelectedRecords();if(s&&s.length){var m=ig.getViews('grid').model;apex.item('P11_ASSET_ID').setValue(String(m.getValue(s[0],'ASSET_ID')));}
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )
    )

    dynamicAction da-job-change (
        name: Job changed - reset + show its assets
        execution {
            sequence: 105
        }
        when {
            event: change
            selectionType: items
            items: P11_JOB_ID
        }
        action js-clear-on-job (
            action: executeJsCode
            settings {
                jsCode: window.kmleonEditor.clear();
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )
        action srv-reset-job (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                      :P11_ASSET_ID := null;
                      :P11_GEOJSON  := null;
                      :P11_NAME     := null;
                      :P11_FOLDER   := null;
                    end;
                    ```
                itemsToReturn: P11_ASSET_ID,P11_GEOJSON,P11_NAME,P11_FOLDER
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )
        action refresh-asset-on-job (
            action: refresh
            affectedElements {
                selectionType: region
                region: @assetgrid
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )
        action refresh-map-on-job (
            action: refresh
            affectedElements {
                selectionType: region
                region: @editmap
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )
    )

    dynamicAction da-clear-new (
        name: New / clear
        execution {
            sequence: 120
        }
        when {
            event: click
            selectionType: button
            button: @clear-new
        }
        action js-clear-new (
            action: executeJsCode
            settings {
                jsCode: window.kmleonEditor.clear();
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )
        action srv-clear (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                      :P11_ASSET_ID := null;
                      :P11_GEOJSON  := null;
                      :P11_NAME     := null;
                      :P11_FOLDER   := null;
                    end;
                    ```
                itemsToReturn: P11_ASSET_ID,P11_GEOJSON,P11_NAME,P11_FOLDER
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )
        action msg-clear (
            action: showSuccessMessage
            settings {
                message: Cleared - ready for a new geometry.
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )
    )

)
