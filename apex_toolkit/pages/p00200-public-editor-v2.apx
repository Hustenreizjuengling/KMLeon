                      <summary><span class="fa fa-map-pin"></span> Icon</summary>
                      <div class="k2-acc-body">
                        <label class="k2-field"><span>Icon URL</span><input type="text" id="k2-icon-href" placeholder="https://&hellip;/icon.png"></label>
                        <label class="k2-field"><span>Icon scale</span><input type="number" step="0.1" id="k2-icon-scale" placeholder="1.0"></label>
                      </div>
                    </details>
                    <details class="k2-acc">
                      <summary><span class="fa fa-cubes"></span> 3D &amp; advanced</summary>
                      <div class="k2-acc-body">
                        <label class="k2-field"><span>Altitude mode</span><select id="k2-altitude"><option value="">(default)</option><option>clampToGround</option><option>relativeToGround</option><option>absolute</option></select></label>
                        <div class="k2-row2">
                          <label class="k2-field"><span>Extrude</span><select id="k2-extrude"><option value="N">No</option><option value="Y">Yes</option></select></label>
                          <label class="k2-field"><span>Tessellate</span><select id="k2-tessellate"><option value="N">No</option><option value="Y">Yes</option></select></label>
                        </div>
