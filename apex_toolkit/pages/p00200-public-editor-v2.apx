    region features (
        name: Features
        type: staticContent
        layout {
            sequence: 20
            slot: body
            columnSpan: 3
            startNewRow: true
        }
        advanced {
            htmlDomId: kml2features
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        source {
            htmlCode:
                ```html
                <div class="k2-panel">
                  <div class="k2-panel-head"><span class="fa fa-list-ul"></span><h3>Features</h3><span class="k2-pill"><span class="k2-count">0</span></span></div>
                  <div class="k2-search"><span class="fa fa-search"></span><input type="text" id="k2-search" placeholder="Search features&hellip;" oninput="window.kml2.filter()"></div>
                  <div id="k2-list" class="k2-list"></div>
                  <button type="button" class="k2-btn k2-btn-ghost k2-newbtn" onclick="window.kml2.newFeature()"><span class="fa fa-plus"></span> New feature</button>
                </div>
                ```
        }
    )

    region map (
        name: Map
        type: map
        layout {
            sequence: 30
            slot: body
            columnSpan: 6
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: kml2map
        }
        map {
            height: 640
        }
        controls {
            options: [
                mousewheelZoom
                scaleBar
                overviewMap
            ]
        }
        initialPositionAndZoom {
            type: sqlQuery
            sqlQuery:
                ```sql
                select 13.40 as map_lon, 52.52 as map_lat, 4 as zoom_level from dual
                ```
            geometryColumnDataType: longitudeLatitude
            initialLongitudeColumn: MAP_LON
            initialLatitudeColumn: MAP_LAT
            initialZoomlevelColumn: ZOOM_LEVEL
        }

        layer saved (
            name: Saved features
            label {
                label: Saved features
            }
            layout {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select asset_id as id,
                           name,
                           nvl(geometry_geojson, sdo_util.to_geojson(geometry_sdo)) as geojson
                      from kml_job_assets a
                     where a.job_id = to_number(:P200_JOB_ID)
                       and exists (select 1 from kml_jobs j
                                    where j.job_id = to_number(:P200_JOB_ID)
                                      and j.access_key = :P200_ACCESS_KEY)
                    ```
                pageItemsToSubmit: P200_JOB_ID,P200_ACCESS_KEY
            }
            columnMapping {
                geometryColumnDataType: geojson
                geojsonColumn: GEOJSON
                primaryKeyColumn: ID
            }
            appearance {
                fillColor: #16a34a
            }
            tooltip {
                advancedFormatting: true
                htmlExpression: &NAME.
            }
        )

    )

