    process list-assets (
        name: LIST_ASSETS
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  l_job  number := to_number(:P200_JOB_ID);
                  l_n    number;
                  l_name kml_jobs.document_name%type;
                  l_fmt  kml_jobs.output_format%type;
                begin
                  select count(*) into l_n from kml_jobs where job_id = l_job and access_key = :P200_ACCESS_KEY;
                  if l_n = 0 then
                    raise_application_error(-20902, 'Invalid access key.');
                  end if;
                  select document_name, output_format into l_name, l_fmt from kml_jobs where job_id = l_job;
                  apex_json.open_object;
                  apex_json.open_object('job');
                  apex_json.write('name', l_name);
                  apex_json.write('format', l_fmt);
                  apex_json.close_object;
                  apex_json.open_array('features');
                  for r in (select asset_id, name,
                                   case when geometry_geojson is not null then 'GeoJSON'
                                        when geometry_sdo is not null then 'SDO' end as geom,
                                   folder_name, line_color, poly_color
                              from kml_job_assets
                             where job_id = l_job
                             order by display_order, asset_id) loop
                    apex_json.open_object;
                    apex_json.write('asset_id', r.asset_id);
                    apex_json.write('name', r.name);
                    apex_json.write('geom', r.geom);
                    apex_json.write('folder', r.folder_name);
                    apex_json.write('line_color', nvl(pck_kmleon_tools.kml_to_rgb(r.line_color), '#3388ff'));
                    apex_json.write('poly_color', nvl(pck_kmleon_tools.kml_to_rgb(r.poly_color), '#3388ff'));
                    apex_json.close_object;
                  end loop;
                  apex_json.close_array;
                  apex_json.close_object;
                end;
                ```
        }
        execution {
            sequence: 20
            point: ajaxCallback
        }
    )

    process load-asset (
        name: LOAD_ASSET
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  l_a kml_job_assets%rowtype;
                  l_n number;
                begin
                  select count(*) into l_n from kml_jobs
                   where job_id = to_number(:P200_JOB_ID) and access_key = :P200_ACCESS_KEY;
                  if l_n = 0 then
                    raise_application_error(-20902, 'Invalid access key.');
                  end if;
                  select * into l_a from kml_job_assets
                   where asset_id = to_number(apex_application.g_x01)
                     and job_id   = to_number(:P200_JOB_ID);
                  apex_json.open_object;
                  apex_json.write('asset_id', l_a.asset_id);
                  apex_json.write('geojson', nvl(l_a.geometry_geojson, sdo_util.to_geojson(l_a.geometry_sdo)));
                  apex_json.write('name', l_a.name);
                  apex_json.write('folder', l_a.folder_name);
                  apex_json.write('line_color', nvl(pck_kmleon_tools.kml_to_rgb(l_a.line_color), '#3388ff'));
                  apex_json.write('line_width', nvl(l_a.line_width, 2));
                  apex_json.write('poly_color', nvl(pck_kmleon_tools.kml_to_rgb(l_a.poly_color), '#3388ff'));
                  apex_json.write('poly_alpha', nvl(pck_kmleon_tools.kml_alpha(l_a.poly_color), 128));
                  apex_json.write('poly_fill', nvl(l_a.poly_fill, 'Y'));
                  apex_json.write('poly_outline', nvl(l_a.poly_outline, 'Y'));
                  apex_json.write('label_color', pck_kmleon_tools.kml_to_rgb(l_a.label_color));
                  apex_json.write('label_scale', l_a.label_scale);
                  apex_json.write('icon_href', l_a.icon_href);
                  apex_json.write('icon_scale', l_a.icon_scale);
                  apex_json.write('altitude_mode', l_a.altitude_mode);
                  apex_json.write('extrude', nvl(l_a.extrude, 'N'));
                  apex_json.write('tessellate', nvl(l_a.tessellate, 'N'));
                  apex_json.write('ext_data', l_a.extended_data);
                  apex_json.close_object;
                end;
                ```
        }
        execution {
            sequence: 30
            point: ajaxCallback
        }
    )

    process save-asset (
        name: SAVE_ASSET
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  l_job  number := to_number(:P200_JOB_ID);
                  l_n    number;
                  l_aid  number := json_value(:P200_PAYLOAD, '$.asset_id' returning number);
                  l_gj   clob   := json_value(:P200_PAYLOAD, '$.geojson' returning clob);
                  l_lc   varchar2(20) := json_value(:P200_PAYLOAD, '$.line_color');
                  l_pc   varchar2(20) := json_value(:P200_PAYLOAD, '$.poly_color');
                  l_lbc  varchar2(20) := json_value(:P200_PAYLOAD, '$.label_color');
                  l_pa   number := json_value(:P200_PAYLOAD, '$.poly_alpha' returning number);
                  l_line varchar2(8) := case when json_value(:P200_PAYLOAD, '$.line_color') is not null then pck_kml_engine.rgba_to_kml(ltrim(l_lc, '#')) end;
                  l_poly varchar2(8) := case when json_value(:P200_PAYLOAD, '$.poly_color') is not null then pck_kml_engine.rgba_to_kml(ltrim(l_pc, '#'), nvl(l_pa, 128)) end;
                  l_lbl  varchar2(8) := case when json_value(:P200_PAYLOAD, '$.label_color') is not null then pck_kml_engine.rgba_to_kml(ltrim(l_lbc, '#')) end;
                begin
                  select count(*) into l_n from kml_jobs where job_id = l_job and access_key = :P200_ACCESS_KEY;
                  if l_n = 0 then
                    raise_application_error(-20902, 'Invalid access key.');
                  end if;
                  if l_gj is null then
                    raise_application_error(-20900, 'Draw a geometry first.');
                  end if;

                  if l_aid is not null then
                    select count(*) into l_n from kml_job_assets where asset_id = l_aid and job_id = l_job;
                    if l_n = 0 then
                      raise_application_error(-20901, 'Feature does not belong to this job.');
                    end if;
                    pck_kml_job_assets_dml.upd(
                      p_asset_id         => l_aid,
                      p_geometry_geojson => l_gj,
                      p_name             => json_value(:P200_PAYLOAD, '$.name'),
                      p_folder_name      => json_value(:P200_PAYLOAD, '$.folder'),
                      p_line_color       => l_line,
                      p_line_width       => json_value(:P200_PAYLOAD, '$.line_width' returning number),
                      p_poly_color       => l_poly,
                      p_poly_fill        => json_value(:P200_PAYLOAD, '$.poly_fill'),
                      p_poly_outline     => json_value(:P200_PAYLOAD, '$.poly_outline'),
                      p_label_color      => l_lbl,
                      p_label_scale      => json_value(:P200_PAYLOAD, '$.label_scale' returning number),
                      p_icon_href        => json_value(:P200_PAYLOAD, '$.icon_href'),
                      p_icon_scale       => json_value(:P200_PAYLOAD, '$.icon_scale' returning number),
                      p_altitude_mode    => json_value(:P200_PAYLOAD, '$.altitude_mode'),
                      p_extrude          => nvl(json_value(:P200_PAYLOAD, '$.extrude'), 'N'),
                      p_tessellate       => nvl(json_value(:P200_PAYLOAD, '$.tessellate'), 'N'),
                      p_extended_data    => json_value(:P200_PAYLOAD, '$.ext_data' returning clob));
                  else
                    l_aid := pck_kml_job_api.add_asset(
                               p_job_id           => l_job,
                               p_geometry_geojson => l_gj,
                               p_name             => json_value(:P200_PAYLOAD, '$.name'),
                               p_folder_name      => json_value(:P200_PAYLOAD, '$.folder'),
                               p_line_color       => l_line,
                               p_line_width       => json_value(:P200_PAYLOAD, '$.line_width' returning number),
                               p_poly_color       => l_poly,
                               p_poly_fill        => json_value(:P200_PAYLOAD, '$.poly_fill'),
                               p_poly_outline     => json_value(:P200_PAYLOAD, '$.poly_outline'),
                               p_label_color      => l_lbl,
                               p_label_scale      => json_value(:P200_PAYLOAD, '$.label_scale' returning number),
                               p_icon_href        => json_value(:P200_PAYLOAD, '$.icon_href'),
                               p_icon_scale       => json_value(:P200_PAYLOAD, '$.icon_scale' returning number),
                               p_altitude_mode    => json_value(:P200_PAYLOAD, '$.altitude_mode'),
                               p_extrude          => nvl(json_value(:P200_PAYLOAD, '$.extrude'), 'N'),
                               p_tessellate       => nvl(json_value(:P200_PAYLOAD, '$.tessellate'), 'N'),
                               p_extended_data    => json_value(:P200_PAYLOAD, '$.ext_data' returning clob));
                  end if;
                  commit;
                  apex_json.open_object;
                  apex_json.write('asset_id', l_aid);
                  apex_json.close_object;
                end;
                ```
        }
        execution {
            sequence: 40
            point: ajaxCallback
        }
    )

    process delete-asset (
        name: DELETE_ASSET
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  l_job number := to_number(:P200_JOB_ID);
                  l_n   number;
                begin
                  select count(*) into l_n from kml_jobs
                   where job_id = l_job and access_key = :P200_ACCESS_KEY;
                  if l_n = 0 then
                    raise_application_error(-20902, 'Invalid access key.');
                  end if;
                  select count(*) into l_n from kml_job_assets
                   where asset_id = to_number(apex_application.g_x01) and job_id = l_job;
                  if l_n = 0 then
                    raise_application_error(-20901, 'Feature does not belong to this job.');
                  end if;
                  pck_kml_job_assets_dml.del(p_asset_id => to_number(apex_application.g_x01));
                  commit;
                  apex_json.open_object;
                  apex_json.write('status', 'ok');
                  apex_json.close_object;
                end;
                ```
        }
        execution {
            sequence: 50
            point: ajaxCallback
        }
    )

    process stream-download (
        name: DOWNLOAD
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  l_job   number       := to_number(apex_application.g_x01);
                  l_key   varchar2(64)  := apex_application.g_x02;
                  l_n     number;
                  l_fmt   kml_jobs.output_format%type;
                  l_fname varchar2(400);
                  l_kml   clob;
                  l_blob  blob;
                  l_dst   integer := 1;
                  l_src   integer := 1;
                  l_ctx   integer := dbms_lob.default_lang_ctx;
                  l_w     integer;
                begin
                  select count(*) into l_n
                    from kml_jobs
                   where job_id = l_job and access_key = l_key;
                  if l_n = 0 then
                    return;
                  end if;

                  select output_format, nvl(output_filename, 'kmleon_' || job_id)
                    into l_fmt, l_fname
                    from kml_jobs where job_id = l_job;

                  l_kml := pck_kml_engine.build_kml(l_job);

                  if l_fmt = 'KMZ' then
                    l_blob := pck_kml_kmz.zip_kml(l_kml, 'doc.kml');
                    sys.owa_util.mime_header('application/vnd.google-earth.kmz', false);
                    sys.htp.p('Content-Disposition: attachment; filename="' || l_fname || '.kmz"');
                    sys.owa_util.http_header_close;
                    sys.wpg_docload.download_file(l_blob);
                  else
                    dbms_lob.createtemporary(l_blob, true);
                    dbms_lob.converttoblob(l_blob, l_kml, dbms_lob.lobmaxsize, l_dst, l_src,
                                           nls_charset_id('AL32UTF8'), l_ctx, l_w);
                    sys.owa_util.mime_header('application/vnd.google-earth.kml+xml', false);
                    sys.htp.p('Content-Disposition: attachment; filename="' || l_fname || '.kml"');
                    sys.owa_util.http_header_close;
                    sys.wpg_docload.download_file(l_blob);
                  end if;

                  apex_application.stop_apex_engine;
                exception
                  when no_data_found then
                    null;
                end;
                ```
        }
        execution {
            sequence: 60
            point: ajaxCallback
        }
    )

)
