    dynamicAction da-save (
        name: Save feature
        execution {
            sequence: 70
        }
        when {
            event: click
            selectionType: button
            button: @save-asset
        }
        action srv-save (
            action: executeServerSideCode
            settings {
                itemsToSubmit: P100_JOB_ID,P100_ACCESS_KEY,P100_ASSET_ID,P100_GEOJSON,P100_NAME,P100_FOLDER,P100_LINE_COLOR,P100_LINE_WIDTH,P100_POLY_COLOR,P100_POLY_ALPHA,P100_POLY_FILL,P100_POLY_OUTLINE,P100_LABEL_COLOR,P100_LABEL_SCALE,P100_ICON_HREF,P100_ICON_SCALE,P100_ALTITUDE_MODE,P100_EXTRUDE,P100_TESSELLATE,P100_EXT_DATA
                plsqlCode:
                    ```plsql
                    declare
                      l_job   number := to_number(:P100_JOB_ID);
                      l_n     number;
                      l_a     number;
                      l_line  varchar2(8) := case when :P100_LINE_COLOR  is not null then pck_kml_engine.rgba_to_kml(ltrim(:P100_LINE_COLOR,'#')) end;
                      l_poly  varchar2(8) := case when :P100_POLY_COLOR  is not null then pck_kml_engine.rgba_to_kml(ltrim(:P100_POLY_COLOR,'#'), nvl(:P100_POLY_ALPHA,128)) end;
                      l_label varchar2(8) := case when :P100_LABEL_COLOR is not null then pck_kml_engine.rgba_to_kml(ltrim(:P100_LABEL_COLOR,'#')) end;
                    begin
                      -- re-validate the access key (defence in depth)
                      select count(*) into l_n from kml_jobs where job_id = l_job and access_key = :P100_ACCESS_KEY;
                      if l_n = 0 then
                        raise_application_error(-20902, 'Invalid access key.');
                      end if;
                      if :P100_GEOJSON is null then
                        raise_application_error(-20900, 'Draw a geometry first.');
                      end if;

                      if :P100_ASSET_ID is not null then
                        -- the asset must belong to this job
                        select count(*) into l_n
                          from kml_job_assets
                         where asset_id = to_number(:P100_ASSET_ID) and job_id = l_job;
                        if l_n = 0 then
                          raise_application_error(-20901, 'Feature does not belong to this job.');
                        end if;
                        pck_kml_job_assets_dml.upd(
                          p_asset_id         => to_number(:P100_ASSET_ID),
                          p_geometry_geojson => to_clob(:P100_GEOJSON),
                          p_name             => :P100_NAME,
                          p_folder_name      => :P100_FOLDER,
                          p_line_color       => l_line,
                          p_line_width       => :P100_LINE_WIDTH,
                          p_poly_color       => l_poly,
                          p_poly_fill        => :P100_POLY_FILL,
                          p_poly_outline     => :P100_POLY_OUTLINE,
                          p_label_color      => l_label,
                          p_label_scale      => :P100_LABEL_SCALE,
                          p_icon_href        => :P100_ICON_HREF,
                          p_icon_scale       => :P100_ICON_SCALE,
                          p_altitude_mode    => :P100_ALTITUDE_MODE,
                          p_extrude          => nvl(:P100_EXTRUDE,'N'),
                          p_tessellate       => nvl(:P100_TESSELLATE,'N'),
                          p_extended_data    => to_clob(:P100_EXT_DATA));
                      else
                        l_a := pck_kml_job_api.add_asset(
                                 p_job_id           => l_job,
                                 p_geometry_geojson => to_clob(:P100_GEOJSON),
                                 p_name             => :P100_NAME,
                                 p_folder_name      => :P100_FOLDER,
                                 p_line_color       => l_line,
                                 p_line_width       => :P100_LINE_WIDTH,
                                 p_poly_color       => l_poly,
                                 p_poly_fill        => :P100_POLY_FILL,
                                 p_poly_outline     => :P100_POLY_OUTLINE,
                                 p_label_color      => l_label,
                                 p_label_scale      => :P100_LABEL_SCALE,
                                 p_icon_href        => :P100_ICON_HREF,
                                 p_icon_scale       => :P100_ICON_SCALE,
                                 p_altitude_mode    => :P100_ALTITUDE_MODE,
                                 p_extrude          => nvl(:P100_EXTRUDE,'N'),
                                 p_tessellate       => nvl(:P100_TESSELLATE,'N'),
                                 p_extended_data    => to_clob(:P100_EXT_DATA));
                        :P100_ASSET_ID := l_a;
                      end if;
                      commit;
                    end;
                    ```
                itemsToReturn: P100_ASSET_ID
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )
        action refresh-grid (
            action: refresh
            affectedElements {
                selectionType: region
                region: @assetgrid
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )
        action refresh-map (
            action: refresh
            affectedElements {
                selectionType: region
                region: @editmap
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )
        action msg-save (
            action: showSuccessMessage
            settings {
                message: Saved - it stays loaded so you can keep editing.
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )
        action js-stopdraw (
            action: executeJsCode
            settings {
                jsCode: window.kmleonEditor.stopDraw();
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )
    )

    dynamicAction da-ig-select (
        name: Feature row selected
        execution {
            sequence: 80
        }
        when {
            event: region/interactiveGrid/interactivegridselectionchange
            selectionType: region
            region: @assetgrid
        }
        action js-ig-select (
            action: executeJsCode
            settings {
                jsCode: var ig=apex.region('assetgrid').widget().interactiveGrid('instance'),s=ig.getSelectedRecords();if(s&&s.length){var m=ig.getViews('grid').model;apex.item('P100_ASSET_ID').setValue(String(m.getValue(s[0],'ASSET_ID')));}
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )
    )

    dynamicAction da-load (
        name: Load or clear on feature change
        execution {
            sequence: 90
        }
        when {
            event: change
            selectionType: items
            items: P100_ASSET_ID
        }
        action srv-load (
            action: executeServerSideCode
            settings {
                itemsToSubmit: P100_JOB_ID,P100_ACCESS_KEY,P100_ASSET_ID
                itemsToReturn: P100_GEOJSON,P100_NAME,P100_FOLDER,P100_LINE_COLOR,P100_LINE_WIDTH,P100_POLY_COLOR,P100_POLY_ALPHA,P100_POLY_FILL,P100_POLY_OUTLINE,P100_LABEL_COLOR,P100_LABEL_SCALE,P100_ICON_HREF,P100_ICON_SCALE,P100_ALTITUDE_MODE,P100_EXTRUDE,P100_TESSELLATE,P100_EXT_DATA
                plsqlCode:
                    ```plsql
                    declare
                      l_a kml_job_assets%rowtype;
                      l_n number;
                    begin
                      -- access_key gate (independent of any auth-scheme caching)
                      select count(*) into l_n from kml_jobs
                       where job_id = to_number(:P100_JOB_ID) and access_key = :P100_ACCESS_KEY;
                      if l_n = 0 then
                        raise_application_error(-20902, 'Invalid access key.');
                      end if;
                      if :P100_ASSET_ID is null then
                        :P100_GEOJSON      := null;
                        :P100_NAME         := null;
                        :P100_FOLDER       := null;
                        :P100_LINE_COLOR   := '#3388ff';
                        :P100_LINE_WIDTH   := 2;
                        :P100_POLY_COLOR   := '#3388ff';
                        :P100_POLY_ALPHA   := 128;
                        :P100_POLY_FILL    := 'Y';
                        :P100_POLY_OUTLINE := 'Y';
                        :P100_LABEL_COLOR  := null;
                        :P100_LABEL_SCALE  := null;
                        :P100_ICON_HREF    := null;
                        :P100_ICON_SCALE   := null;
                        :P100_ALTITUDE_MODE := null;
                        :P100_EXTRUDE      := 'N';
                        :P100_TESSELLATE   := 'N';
                        :P100_EXT_DATA     := null;
                      else
                        select * into l_a
                          from kml_job_assets
                         where asset_id = to_number(:P100_ASSET_ID)
                           and job_id   = to_number(:P100_JOB_ID);
                        :P100_GEOJSON      := nvl(l_a.geometry_geojson, sdo_util.to_geojson(l_a.geometry_sdo));
                        :P100_NAME         := l_a.name;
                        :P100_FOLDER       := l_a.folder_name;
                        :P100_LINE_COLOR   := nvl(pck_kmleon_tools.kml_to_rgb(l_a.line_color), '#3388ff');
                        :P100_LINE_WIDTH   := nvl(l_a.line_width, 2);
                        :P100_POLY_COLOR   := nvl(pck_kmleon_tools.kml_to_rgb(l_a.poly_color), '#3388ff');
                        :P100_POLY_ALPHA   := nvl(pck_kmleon_tools.kml_alpha(l_a.poly_color), 128);
                        :P100_POLY_FILL    := nvl(l_a.poly_fill, 'Y');
                        :P100_POLY_OUTLINE := nvl(l_a.poly_outline, 'Y');
                        :P100_LABEL_COLOR  := pck_kmleon_tools.kml_to_rgb(l_a.label_color);
                        :P100_LABEL_SCALE  := l_a.label_scale;
                        :P100_ICON_HREF    := l_a.icon_href;
                        :P100_ICON_SCALE   := l_a.icon_scale;
                        :P100_ALTITUDE_MODE := l_a.altitude_mode;
                        :P100_EXTRUDE      := nvl(l_a.extrude, 'N');
                        :P100_TESSELLATE   := nvl(l_a.tessellate, 'N');
                        :P100_EXT_DATA     := l_a.extended_data;
                      end if;
                    end;
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )
        action js-load (
            action: executeJsCode
            settings {
                jsCode: var g = apex.item('P100_GEOJSON').getValue(); if (g) { window.kmleonEditor.load(g); } else { window.kmleonEditor.clear(); }
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )
    )

