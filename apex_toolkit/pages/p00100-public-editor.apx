    process init-defaults (
        name: Initialise inputs
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  :P100_LINE_COLOR   := nvl(:P100_LINE_COLOR, '#3388ff');
                  :P100_POLY_COLOR   := nvl(:P100_POLY_COLOR, '#3388ff');
                  :P100_LINE_WIDTH   := nvl(:P100_LINE_WIDTH, 2);
                  :P100_POLY_ALPHA   := nvl(:P100_POLY_ALPHA, 128);
                  :P100_POLY_FILL    := nvl(:P100_POLY_FILL, 'Y');
                  :P100_POLY_OUTLINE := nvl(:P100_POLY_OUTLINE, 'Y');
                  :P100_EXTRUDE      := nvl(:P100_EXTRUDE, 'N');
                  :P100_TESSELLATE   := nvl(:P100_TESSELLATE, 'N');
                end;
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
    )

    process stream-download (
        name: DOWNLOAD
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  l_job   number       := to_number(apex_application.g_x01);
                  l_key   varchar2(64)  := apex_application.g_x02;
                  l_n     number;
                  l_fmt   kml_jobs.output_format%type;
                  l_fname varchar2(400);
                  l_kml   clob;
                  l_blob  blob;
                  l_dst   integer := 1;
                  l_src   integer := 1;
                  l_ctx   integer := dbms_lob.default_lang_ctx;
                  l_w     integer;
                begin
                  -- the access_key is the gate (re-validated on every request)
                  select count(*) into l_n
                    from kml_jobs
                   where job_id = l_job and access_key = l_key;
                  if l_n = 0 then
                    return;
                  end if;

                  select output_format, nvl(output_filename, 'kmleon_' || job_id)
                    into l_fmt, l_fname
                    from kml_jobs where job_id = l_job;

                  -- build on the fly; does NOT submit/finish the job or delete assets
                  l_kml := pck_kml_engine.build_kml(l_job);

                  if l_fmt = 'KMZ' then
                    l_blob := pck_kml_kmz.zip_kml(l_kml, 'doc.kml');
                    sys.owa_util.mime_header('application/vnd.google-earth.kmz', false);
                    sys.htp.p('Content-Disposition: attachment; filename="' || l_fname || '.kmz"');
                    sys.owa_util.http_header_close;
                    sys.wpg_docload.download_file(l_blob);
                  else
                    dbms_lob.createtemporary(l_blob, true);
                    dbms_lob.converttoblob(l_blob, l_kml, dbms_lob.lobmaxsize, l_dst, l_src,
                                           nls_charset_id('AL32UTF8'), l_ctx, l_w);
                    sys.owa_util.mime_header('application/vnd.google-earth.kml+xml', false);
                    sys.htp.p('Content-Disposition: attachment; filename="' || l_fname || '.kml"');
                    sys.owa_util.http_header_close;
                    sys.wpg_docload.download_file(l_blob);
                  end if;

                  apex_application.stop_apex_engine;
                exception
                  when no_data_found then
                    null;
                end;
                ```
        }
        execution {
            sequence: 10
            point: ajaxCallback
        }
    )

    process delete-asset (
        name: DELETE_ASSET
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  l_job number := to_number(:P100_JOB_ID);
                  l_n   number;
                begin
                  -- access_key gate
                  select count(*) into l_n from kml_jobs
                   where job_id = l_job and access_key = :P100_ACCESS_KEY;
                  if l_n = 0 then
                    raise_application_error(-20902, 'Invalid access key.');
                  end if;
                  -- the feature must belong to this job
                  select count(*) into l_n from kml_job_assets
                   where asset_id = to_number(apex_application.g_x01) and job_id = l_job;
                  if l_n = 0 then
                    raise_application_error(-20901, 'Feature does not belong to this job.');
                  end if;
                  pck_kml_job_assets_dml.del(p_asset_id => to_number(apex_application.g_x01));
                  commit;
                  apex_json.open_object;
                  apex_json.write('status', 'ok');
                  apex_json.close_object;
                end;
                ```
        }
        execution {
            sequence: 20
            point: ajaxCallback
        }
    )

