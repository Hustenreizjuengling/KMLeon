page 100 (
    name: Public editor
    alias: PUBLIC-EDITOR
    title: KMLeon - Edit your map
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            window.kmleonEditor = (function () {
                var cfg = { prefix: "P11", regionId: "editmap" };
                var map = null, type = null, coords = [], SRC = "kmlDraw", inited = false;
                function it(s) { return apex.item(cfg.prefix + "_" + s); }
                function iv(s) { try { return it(s).getValue(); } catch (e) { return null; } }

                function geom() {
                    if (type === "Point")      return coords.length ? { type: "Point", coordinates: coords[0] } : null;
                    if (type === "LineString") return coords.length >= 2 ? { type: "LineString", coordinates: coords.slice() } : null;
                    if (type === "Polygon") {
                        if (coords.length < 3) return null;
                        var r = coords.slice(); r.push(coords[0]);
                        return { type: "Polygon", coordinates: [r] };
                    }
                    return null;
                }
                function fc() {
                    var feats = [], g = geom();
                    if (g) feats.push({ type: "Feature", properties: {}, geometry: g });
                    if (type === "LineString" || type === "Polygon") {
                        coords.forEach(function (c) {
                            feats.push({ type: "Feature", properties: { vertex: 1 }, geometry: { type: "Point", coordinates: c } });
                        });
                    }
                    return { type: "FeatureCollection", features: feats };
                }
                function redraw() {
                    if (map && map.getSource(SRC)) { map.getSource(SRC).setData(fc()); }
                    var g = geom();
                    it("GEOJSON").setValue(g ? JSON.stringify(g) : "");
                }
                function bounds() {
                    if (!coords.length) { return null; }
                    var minx = 180, miny = 90, maxx = -180, maxy = -90;
                    coords.forEach(function (c) {
                        if (c[0] < minx) minx = c[0]; if (c[0] > maxx) maxx = c[0];
                        if (c[1] < miny) miny = c[1]; if (c[1] > maxy) maxy = c[1];
                    });
                    return [[minx, miny], [maxx, maxy]];
                }
                function applyStyle() {
                    if (!map) { return; }
                    var lc = iv("LINE_COLOR") || "#3388ff";
                    var pc = iv("POLY_COLOR") || "#3388ff";
                    var lw = parseFloat(iv("LINE_WIDTH")) || 2;
                    var pa = (parseFloat(iv("POLY_ALPHA")) || 128) / 255;
                    var fill = iv("POLY_FILL") !== "N";
                    if (map.getLayer("kmlFill"))  { map.setPaintProperty("kmlFill", "fill-color", pc); map.setPaintProperty("kmlFill", "fill-opacity", fill ? pa : 0); }
                    if (map.getLayer("kmlLine"))  { map.setPaintProperty("kmlLine", "line-color", lc); map.setPaintProperty("kmlLine", "line-width", lw); }
                    if (map.getLayer("kmlPoint")) { map.setPaintProperty("kmlPoint", "circle-color", lc); }
                }
                function onClick(e) {
                    if (!type) { return; }
                    var c = [e.lngLat.lng, e.lngLat.lat];
                    if (type === "Point") { coords = [c]; } else { coords.push(c); }
                    redraw();
                }
                function markActive(t) {
                    ["point", "line", "polygon"].forEach(function (m) {
                        var el = document.getElementById("B_" + m.toUpperCase());
                        if (el) { el.classList.toggle("kml-tool-active", m === t); }
                    });
                }
                return {
                    init: function (opts) {
                        if (opts) { if (opts.prefix) { cfg.prefix = opts.prefix; } if (opts.regionId) { cfg.regionId = opts.regionId; } }
                        if (inited) { return; }
                        var r = apex.region(cfg.regionId);
                        if (!r) { return; }
                        map = (typeof r.getMapObject === "function") ? r.getMapObject() : null;
                        if (!map) { return; }
                        inited = true;
                        if (!map.getSource(SRC)) {
                            map.addSource(SRC, { type: "geojson", data: fc() });
                            map.addLayer({ id: "kmlFill", type: "fill", source: SRC, filter: ["==", "$type", "Polygon"],
                                paint: { "fill-color": "#3388ff", "fill-opacity": 0.4 } });
                            map.addLayer({ id: "kmlLine", type: "line", source: SRC, filter: ["in", "$type", "LineString", "Polygon"],
                                paint: { "line-color": "#3388ff", "line-width": 2 } });
                            map.addLayer({ id: "kmlPoint", type: "circle", source: SRC, filter: ["==", "$type", "Point"],
                                paint: { "circle-radius": 5, "circle-color": "#3388ff", "circle-stroke-width": 1, "circle-stroke-color": "#ffffff" } });
                        }
                        map.on("click", onClick);
                        map.on("dblclick", function (e) { if (type === "LineString" || type === "Polygon") { e.preventDefault(); kmleonEditor.finish(); } });
                        ["LINE_COLOR", "POLY_COLOR", "LINE_WIDTH", "POLY_ALPHA", "POLY_FILL"].forEach(function (n) {
                            try { it(n).element.on("change", applyStyle); } catch (e) {}
                        });
                        applyStyle();
                    },
                    setMode: function (t) {
                        type = (t === "point") ? "Point" : (t === "line") ? "LineString" : (t === "polygon") ? "Polygon" : null;
                        coords = [];
                        markActive(t);
                        if (map && map.doubleClickZoom) { if (type === "LineString" || type === "Polygon") { map.doubleClickZoom.disable(); } else { map.doubleClickZoom.enable(); } }
                        redraw();
                        apex.message.showPageSuccess("Draw mode: " + t + " - click on the map (double-click finishes a line/polygon).");
                    },
                    undo: function () { if (coords.length) { coords.pop(); } redraw(); },
                    clear: function () { type = null; coords = []; markActive(null); redraw(); },
                    stopDraw: function () { type = null; markActive(null); if (map && map.doubleClickZoom) { map.doubleClickZoom.enable(); } },
                    finish: function () { redraw(); apex.message.showPageSuccess("Geometry captured. Set the style, then save it."); },
                    load: function (gjStr) {
                        try {
                            var g = JSON.parse(gjStr);
                            if (g && g.type === "FeatureCollection" && g.features && g.features.length) { g = g.features[0].geometry; }
                            else if (g && g.type === "Feature") { g = g.geometry; }
                            if (!g || !g.type) { return; }
                            if (g.type === "Point") { type = "Point"; coords = [g.coordinates]; }
                            else if (g.type === "LineString") { type = "LineString"; coords = g.coordinates.slice(); }
                            else if (g.type === "Polygon") {
                                type = "Polygon";
                                var r = g.coordinates[0].slice();
                                if (r.length > 1 && r[0][0] === r[r.length-1][0] && r[0][1] === r[r.length-1][1]) { r.pop(); }
                                coords = r;
                            } else { return; }
                            redraw();
                            applyStyle();
                            var b = bounds();
                            if (map && b) { try { map.fitBounds(b, { padding: 60, maxZoom: 15, duration: 600 }); } catch (e) {} }
                        } catch (e) {}
                    },
                    applyStyle: applyStyle
                };
            })();

            // On-the-fly download: navigate to the page's DOWNLOAD ajax process. The
            // process streams the file via owa_util/htp.p with a content-disposition
            // attachment, so the browser downloads it and stays on this page. job_id +
            // access_key go as x01/x02 (ajax params -> no URL checksum needed).
            window.kmleonPublicDownload = function () {
                var p = window.location.pathname,
                    o = p.substring(0, p.indexOf("/r/")),
                    c = p.split("/").slice(-2).join("/") + "/" + $v("pInstance"),
                    u = window.location.origin + o + "/wwv_flow.ajax?p_context=" + encodeURIComponent(c) +
                        "&p_flow_id=" + $v("pFlowId") + "&p_flow_step_id=" + $v("pFlowStepId") +
                        "&p_instance=" + $v("pInstance") +
                        "&p_request=" + encodeURIComponent("APPLICATION_PROCESS=DOWNLOAD") +
                        "&x01=" + encodeURIComponent($v("P100_JOB_ID")) +
                        "&x02=" + encodeURIComponent($v("P100_ACCESS_KEY"));
                window.location.href = u;
            };
            ```
        executeWhenPageLoads:
            ```javascript-browser
            (function () {
                function ready() {
                    try { var r = apex.region("editmap"); return r && typeof r.getMapObject === "function" && r.getMapObject(); }
                    catch (e) { return false; }
                }
                function tryInit(n) {
                    if (ready()) { window.kmleonEditor.init({ prefix: "P100" }); return; }
                    if (n > 0) { setTimeout(function () { tryInit(n - 1); }, 500); }
                }
                apex.jQuery("#editmap").on("spatialmapinitialized", function () { window.kmleonEditor.init({ prefix: "P100" }); });
                tryInit(30);

                // Delete a feature straight from the grid: a per-row button carries the
                // asset id; this delegated handler calls the DELETE_ASSET ajax process
                // (job id + access_key submitted as page items and re-validated server-side).
                apex.jQuery(document).on("click", ".kml-del-asset", function () {
                    var id = apex.jQuery(this).data("assetId");
                    if (!id) { return; }
                    apex.message.confirm("Delete this feature? This cannot be undone.", function (ok) {
                        if (!ok) { return; }
                        apex.server.process("DELETE_ASSET",
                            { x01: id, pageItems: "#P100_JOB_ID,#P100_ACCESS_KEY" },
                            {
                                dataType: "json",
                                success: function () {
                                    if (String(apex.item("P100_ASSET_ID").getValue()) === String(id)) {
                                        apex.item("P100_ASSET_ID").setValue("");
                                        window.kmleonEditor.clear();
                                    }
                                    apex.region("assetgrid").refresh();
                                    apex.region("editmap").refresh();
                                    apex.message.showPageSuccess("Feature deleted.");
                                },
                                error: function () { apex.message.alert("Could not delete the feature."); }
                            });
                    });
                });
            })();
            ```
    }
    security {
        authentication: public
        authorizationScheme: @JOB_ACCESS_VALID
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region intro (
        name: Edit your map
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        advanced {
            htmlDomId: intro
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        source {
            htmlCode:
                ```html
                <style>
                  #style .t-Region-body { max-height:600px; overflow-y:auto; }
                  #style .t-Form-fieldContainer { width:100% !important; max-width:100% !important; }
                  #style #B_POINT, #style #B_LINE, #style #B_POLYGON,
                  #style #B_FINISH, #style #B_UNDO, #style #B_CLEAR {
                    width:calc(33.333% - 8px) !important; display:inline-flex !important;
                    justify-content:center; margin:0 4px 6px 0 !important; padding-left:0; padding-right:0;
                  }
                  .kml-tool-active, .kml-tool-active:hover { background:#0072c6 !important; border-color:#0072c6 !important; color:#fff !important; }
                  .kml-tool-active .t-Icon { color:#fff !important; }
                </style>
                <!-- security-review: public page, gated by the JOB_ACCESS_VALID authorization
                     scheme (matches P100_JOB_ID + P100_ACCESS_KEY against KML_JOBS, re-evaluated
                     per page view). pageAccessProtection stays argumentsMustHaveChecksum; only the
                     two deep-link items are sessionStateProtection unrestricted so an external app
                     can build the link without an APEX checksum. Every query is scoped to the one
                     job; the unguessable access_key is the access control. -->
                <p class="u-textGrey">
                  Draw and style the features of your map, then <b>Download</b> the KML/KMZ when you are
                  happy. Click a row in the list to edit an existing feature, or use the draw tools to add
                  a new one. Your changes are saved to this job only.
                </p>
                ```
        }
    )

    pageItem P100_JOB_ID (
        type: hidden
        layout {
            sequence: 1
            region: @intro
            slot: regionBody
        }
        settings {
            valueProtected: false
        }
        security {
            sessionStateProtection: unrestricted
        }
    )

    pageItem P100_ACCESS_KEY (
        type: hidden
        layout {
            sequence: 2
            region: @intro
            slot: regionBody
        }
        settings {
            valueProtected: false
        }
        security {
            sessionStateProtection: unrestricted
        }
    )

    pageItem P100_GEOJSON (
        type: hidden
        layout {
            sequence: 3
            region: @intro
            slot: regionBody
        }
        settings {
            valueProtected: false
        }
        security {
            sessionStateProtection: unrestricted
        }
    )

    pageItem P100_ASSET_ID (
        type: hidden
        layout {
            sequence: 4
            region: @intro
            slot: regionBody
        }
        settings {
            valueProtected: false
        }
        security {
            sessionStateProtection: unrestricted
        }
    )

    region assetgrid (
        name: Features in your map
        type: interactiveGrid
        layout {
            sequence: 15
            slot: body
            columnSpan: 12
            startNewRow: true
        }
        advanced {
            htmlDomId: assetgrid
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select asset_id,
                       name,
                       case when geometry_geojson is not null then 'GeoJSON'
                            when geometry_sdo is not null then 'SDO' end as geom,
                       folder_name,
                       line_color,
                       poly_color,
                       asset_id as del
                  from kml_job_assets a
                 where a.job_id = to_number(:P100_JOB_ID)
                   and exists (select 1 from kml_jobs j
                                where j.job_id = to_number(:P100_JOB_ID)
                                  and j.access_key = :P100_ACCESS_KEY)
                 order by display_order, asset_id
                ```
            pageItemsToSubmit: P100_JOB_ID,P100_ACCESS_KEY
        }
        edit {
            enabled: false
        }
        pagination {
            type: page
            showTotalCount: true
        }
        messages {
            whenNoDataFound: No features yet - draw one and Save it.
        }
        toolbar {
            controls: [
                searchField
                actionsMenu
            ]
        }

        savedReport PRIMARY (
            name: Primary
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }
            displayColumn (
                column: @APEX$ROW_SELECTOR
                layout {
                    sequence: 0
                }
            )
            displayColumn (
                column: @NAME
                layout {
                    sequence: 1
                }
            )
            displayColumn (
                column: @GEOM
                layout {
                    sequence: 2
                }
            )
            displayColumn (
                column: @FOLDER_NAME
                layout {
                    sequence: 3
                }
            )
            displayColumn (
                column: @LINE_COLOR
                layout {
                    sequence: 4
                }
            )
            displayColumn (
                column: @POLY_COLOR
                layout {
                    sequence: 5
                }
            )
            displayColumn (
                column: @DEL
                layout {
                    sequence: 6
                }
            )
        )

        column APEX$ROW_SELECTOR (
            type: rowSelector
            layout {
                sequence: 10
            }
        )
        column ASSET_ID (
            type: hidden
            layout {
                sequence: 20
            }
            source {
                databaseColumn: ASSET_ID
                dataType: number
                primaryKey: true
            }
        )
        column NAME (
            type: textField
            heading {
                heading: Name
            }
            layout {
                sequence: 30
            }
            source {
                databaseColumn: NAME
                dataType: varchar2
            }
        )
        column GEOM (
            type: textField
            heading {
                heading: Geometry
            }
            layout {
                sequence: 40
            }
            source {
                databaseColumn: GEOM
                dataType: varchar2
            }
        )
        column FOLDER_NAME (
            type: textField
            heading {
                heading: Folder
            }
            layout {
                sequence: 50
            }
            source {
                databaseColumn: FOLDER_NAME
                dataType: varchar2
            }
        )
        column LINE_COLOR (
            type: textField
            heading {
                heading: Line
            }
            layout {
                sequence: 60
            }
            source {
                databaseColumn: LINE_COLOR
                dataType: varchar2
            }
        )
        column POLY_COLOR (
            type: textField
            heading {
                heading: Fill
            }
            layout {
                sequence: 70
            }
            source {
                databaseColumn: POLY_COLOR
                dataType: varchar2
            }
        )
        column DEL (
            type: htmlExpression
            heading {
                heading: Delete
            }
            layout {
                sequence: 80
            }
            source {
                databaseColumn: DEL
                dataType: number
            }
            settings {
                htmlExpression: <button type="button" class="t-Button t-Button--danger t-Button--small kml-del-asset" data-asset-id="&DEL." aria-label="Delete feature"><span class="t-Icon fa fa-trash-o"></span></button>
            }
        )
    )

    region editmap (
        name: Map
        type: map
        layout {
            sequence: 20
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: editmap
        }
        map {
            height: 600
        }
        controls {
            options: [
                mousewheelZoom
                scaleBar
                overviewMap
            ]
        }
        initialPositionAndZoom {
            type: sqlQuery
            sqlQuery:
                ```sql
                select 13.40 as map_lon, 52.52 as map_lat, 4 as zoom_level from dual
                ```
            geometryColumnDataType: longitudeLatitude
            initialLongitudeColumn: MAP_LON
            initialLatitudeColumn: MAP_LAT
            initialZoomlevelColumn: ZOOM_LEVEL
        }

        layer saved (
            name: Saved features
            label {
                label: Saved features
            }
            layout {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select asset_id as id,
                           name,
                           nvl(geometry_geojson, sdo_util.to_geojson(geometry_sdo)) as geojson
                      from kml_job_assets a
                     where a.job_id = to_number(:P100_JOB_ID)
                       and exists (select 1 from kml_jobs j
                                    where j.job_id = to_number(:P100_JOB_ID)
                                      and j.access_key = :P100_ACCESS_KEY)
                    ```
                pageItemsToSubmit: P100_JOB_ID,P100_ACCESS_KEY
            }
            columnMapping {
                geometryColumnDataType: geojson
                geojsonColumn: GEOJSON
                primaryKeyColumn: ID
            }
            appearance {
                fillColor: #16a34a
            }
            tooltip {
                advancedFormatting: true
                htmlExpression: &NAME.
            }
        )

    )

    region style (
        name: Draw and style
        type: staticContent
        layout {
            sequence: 25
            slot: body
            columnSpan: 4
            startNewRow: false
        }
        advanced {
            htmlDomId: style
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
    )

    button b-point (
        buttonName: B_POINT
